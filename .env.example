# ─────────────────────────────────────────────────────────────────────────
# ServerPulse Environment Variables — TEMPLATE
#
# Copy this file to `.env` before starting the application:
#
#     cp .env.example .env
#
# Docker Compose automatically loads `.env` and substitutes the ${VAR}
# values defined in docker-compose.yml.
#
# This file documents every environment variable used by the project.
# The committed `.env.example` contains safe development defaults only.
# Your local `.env` should never be committed to Git.
# ─────────────────────────────────────────────────────────────────────────

# ========================================================================
# PostgreSQL Configuration
# ========================================================================
#
# These variables are injected into the PostgreSQL container and are also
# used by the backend to build the database connection string.
#
POSTGRES_USER=serverpulse
POSTGRES_PASSWORD=serverpulse
POSTGRES_DB=serverpulse

# ========================================================================
# Backend (Node.js API)
# ========================================================================
#
# Internal port that the Express application listens on inside its container.
#
# If this value changes, update the frontend API configuration accordingly.
#
BACKEND_PORT=5000

# ========================================================================
# Frontend (React + Vite)
# ========================================================================
#
# Internal port used by the Vite development server.
# This is only used during development.
#
FRONTEND_PORT=5173

# ========================================================================
# Host Port Mappings
# ========================================================================
#
# These values define the ports exposed on your local machine.
#
POSTGRES_HOST_PORT=5432
BACKEND_HOST_PORT=5000
FRONTEND_HOST_PORT=5173
